{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' http://localhost:8000 http://localhost:3000 https://threathunter-api.onrender.com https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com; frame-ancestors 'none';"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/login/",
      "destination": "https://threathunter-api.onrender.com/api/login/"
    },
    {
      "source": "/api/login",
      "destination": "https://threathunter-api.onrender.com/api/login/"
    },
    {
      "source": "/api/register/",
      "destination": "https://threathunter-api.onrender.com/api/register/"
    },
    {
      "source": "/api/register",
      "destination": "https://threathunter-api.onrender.com/api/register/"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://threathunter-api.onrender.com/api/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "https://threathunter-api.onrender.com/admin/$1"
    },
    {
      "source": "/static/admin/(.*)",
      "destination": "https://threathunter-api.onrender.com/static/admin/$1"
    }
  ]
}
